{
  "name": "emerald_web_fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:coverage": "vitest run --coverage",
    "e2e": "npm --prefix .. run e2e --",
    "e2e:ui": "npm --prefix .. run e2e:ui",
    "test:e2e": "npm --prefix .. run e2e --",
    "lint": "biome check .",
    "format": "biome format . --write",
    "prepare": "husky install || echo husky install skipped"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "biome format --write"
    ]
  },
